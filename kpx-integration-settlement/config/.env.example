# Energy Cashback Settlement — 환경변수 예시
# 실제 값은 .env에 입력 (git 추적 제외)

# OpenAI API (LLM Agent)
OPENAI_API_KEY=your_openai_api_key_here

# DB 연결 (TimescaleDB + pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ax_nilm

# psycopg2 동기 연결 (LLM Agent 도구용, IAP 터널: localhost:5436)
DB_HOST=localhost
DB_PORT=5436
DB_NAME=ax_nilm
DB_USER=ax_nilm_team
DB_PASSWORD=           # GCP Secret Manager: ax-nilm-db-team-password

# Celery 브로커
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LangSmith 트레이싱 (LangGraph 자동 연동)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ax_nilm-kpx

# 에너지캐시백 신청 페이지 (한전 에너지마켓플레이스)
DR_ENROLLMENT_URL=https://en-ter.co.kr/ec/apply/prsApply/select.do
