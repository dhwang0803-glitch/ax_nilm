    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.0",
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.1",
