# API_Server — 환경 변수 템플릿
# 실제 값은 .env 또는 .env.local (커밋 금지) 에 저장

# ─── 앱 설정 ──────────────────────────────────────────
APP_ENV=dev                           # dev | staging | prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ─── CORS ────────────────────────────────────────────
# Frontend dev 서버 (Vite). 프로덕션에서는 실제 도메인 추가
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── 인증 ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-byte-random-string-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080            # 7일

# 쿠키
COOKIE_NAME=ax_nilm_session
COOKIE_SECURE=false                  # prod 에서는 true (HTTPS 필수)
COOKIE_SAMESITE=lax                  # lax | strict | none

# 데모 계정 (Frontend MSW 와 동일 자격증명)
DEMO_USER_EMAIL=test@example.com
DEMO_USER_PASSWORD=nilm-mock-2026!
DEMO_USER_NAME=테스터
DEMO_HOUSEHOLD_ID=H001

# ─── 데이터 소스 ──────────────────────────────────────
# false: 내장 mock 데이터로 응답 (Frontend 즉시 배포용)
# true:  Database/src/repositories 를 통해 실 DB 조회
USE_DB=false

# USE_DB=true 일 때만 사용 (Database/.env 와 동일 형식)
# DATABASE_URL=postgresql+asyncpg://ax_nilm_app:<password>@localhost:5436/ax_nilm
# CREDENTIAL_MASTER_KEY=<Fernet key>
